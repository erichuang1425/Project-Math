{
  "schemaVersion": "1.0",
  "id": "derivatives-first-principles",
  "title": "Derivatives from First Principles",
  "subject": "math",
  "topic": "calculus",
  "summary": "Learn the derivative as the limit of average rates of change.",
  "prerequisites": ["algebra", "functions", "limits"],
  "lessons": [
    {
      "id": "derivative-as-a-limit",
      "title": "Derivative as a Limit",
      "summary": "Connect secant slopes, the difference quotient, and the first-principles definition of a derivative.",
      "objectives": [
        "Explain the derivative as a limit of average rates of change.",
        "Use the difference quotient with h not equal to 0 before the limit is taken.",
        "Compute the derivative of f(x) = x^2 from first principles.",
        "Compute the derivative of a linear function from first principles.",
        "Identify why substituting h = 0 too early is invalid."
      ],
      "estimatedMinutes": 32,
      "sections": [
        {
          "id": "meaning",
          "title": "From Average Slope to Instant Slope",
          "blocks": [
            {
              "type": "title",
              "id": "lesson-title",
              "kicker": "Calculus foundations",
              "title": "Derivatives from First Principles",
              "subtitle": "Start with average rate of change, then let the second point move toward the first.",
              "objectives": [
                [
                  {
                    "kind": "text",
                    "value": "Explain the derivative as a limit of average rates of change."
                  }
                ],
                [
                  {
                    "kind": "text",
                    "value": "Compute the derivative of "
                  },
                  {
                    "kind": "inlineMath",
                    "latex": "f(x)=x^2"
                  },
                  {
                    "kind": "text",
                    "value": " from first principles."
                  }
                ],
                [
                  {
                    "kind": "text",
                    "value": "Use the same definition for a linear function."
                  }
                ]
              ]
            },
            {
              "type": "concept",
              "id": "average-rate-of-change",
              "title": "Average rate of change",
              "body": [
                {
                  "kind": "text",
                  "value": "Between two inputs, the average rate of change is the slope of the secant line: "
                },
                {
                  "kind": "inlineMath",
                  "latex": "\\frac{f(b)-f(a)}{b-a}"
                },
                {
                  "kind": "text",
                  "value": ". The denominator must be nonzero because the two inputs must be distinct."
                }
              ],
              "keyIdeas": [
                [
                  {
                    "kind": "text",
                    "value": "A secant slope compares two points on a graph."
                  }
                ],
                [
                  {
                    "kind": "text",
                    "value": "A derivative asks what happens as those two points move together."
                  }
                ]
              ]
            },
            {
              "type": "intuition",
              "id": "secant-to-tangent-intuition",
              "title": "Why a limit is needed",
              "body": [
                {
                  "kind": "text",
                  "value": "If the second input is "
                },
                {
                  "kind": "inlineMath",
                  "latex": "x+h"
                },
                {
                  "kind": "text",
                  "value": ", then "
                },
                {
                  "kind": "inlineMath",
                  "latex": "h"
                },
                {
                  "kind": "text",
                  "value": " measures the horizontal gap from "
                },
                {
                  "kind": "inlineMath",
                  "latex": "x"
                },
                {
                  "kind": "text",
                  "value": ". Before taking the limit, "
                },
                {
                  "kind": "inlineMath",
                  "latex": "h\\ne 0"
                },
                {
                  "kind": "text",
                  "value": ". The limit lets us study the value the slopes approach as the gap shrinks."
                }
              ],
              "takeaway": [
                {
                  "kind": "text",
                  "value": "Do algebra while "
                },
                {
                  "kind": "inlineMath",
                  "latex": "h\\ne 0"
                },
                {
                  "kind": "text",
                  "value": ", then evaluate the limit."
                }
              ]
            },
            {
              "type": "latex",
              "id": "first-principles-definition",
              "latex": "f'(x)=\\lim_{h\\to 0}\\frac{f(x+h)-f(x)}{h}",
              "caption": "Derivative from first principles",
              "display": true
            },
            {
              "type": "graph",
              "id": "secant-slope-graph",
              "title": "Secant line approaching tangent slope",
