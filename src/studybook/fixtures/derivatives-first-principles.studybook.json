        {
          "id": "calculation",
          "title": "Compute f'(x) from First Principles",
          "blocks": [
            {
              "type": "workedExample",
              "id": "derivative-of-x-squared",
              "title": "Derivative of f(x) = x^2",
              "goal": "Find f'(x) from first principles.",
              "given": "f(x) = x^2",
              "steps": [
                {
                  "id": "start-definition",
                  "label": "Start with the definition",
                  "explanation": "Use the derivative definition before substituting a specific function.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{f(x+h)-f(x)}{h}"
                },
                {
                  "id": "substitute-function",
                  "label": "Substitute f(x) = x^2",
                  "explanation": "Replace f(x+h) with (x+h)^2 and f(x) with x^2.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{(x+h)^2-x^2}{h}"
                },
                {
                  "id": "expand-square",
                  "label": "Expand",
                  "explanation": "Expand the numerator so like terms can cancel.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{x^2+2xh+h^2-x^2}{h}"
                },
                {
                  "id": "combine-terms",
                  "label": "Combine like terms",
                  "explanation": "The x^2 and -x^2 terms cancel in the numerator.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{2xh+h^2}{h}"
                },
                {
                  "id": "factor-h",
                  "label": "Factor h while h is not zero",
                  "explanation": "Before the limit is taken, h is a nonzero gap, so the common factor h can be canceled.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{h(2x+h)}{h},\\quad h\\ne 0"
                },
                {
                  "id": "cancel-h",
                  "label": "Cancel the common factor",
                  "explanation": "After cancellation, the expression no longer divides by h.",
                  "latex": "f'(x)=\\lim_{h\\to 0}(2x+h)"
                },
                {
                  "id": "evaluate-limit",
                  "label": "Evaluate the limit",
                  "explanation": "Now h can approach 0 without causing division by zero.",
                  "latex": "f'(x)=2x"
                }
              ],
              "interpretation": "At any input x, the tangent slope of y = x^2 is 2x."
            },
            {
              "type": "workedExample",
              "id": "derivative-of-linear-function",
              "title": "Derivative of f(x) = 3x - 5",
              "goal": "Find f'(x) from first principles for a linear function.",
              "given": "f(x) = 3x - 5",
              "steps": [
                {
                  "id": "linear-start-definition",
                  "label": "Start with the definition",
                  "explanation": "Use the same first-principles definition. The gap h is nonzero before the limit is taken.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{f(x+h)-f(x)}{h}"
                },
                {
                  "id": "linear-substitute-function",
                  "label": "Substitute f(x) = 3x - 5",
                  "explanation": "Replace f(x+h) with 3(x+h)-5 and subtract the whole expression f(x)=3x-5.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{(3(x+h)-5)-(3x-5)}{h}"
                },
                {
                  "id": "linear-expand",
                  "label": "Expand and distribute the subtraction",
                  "explanation": "Expand 3(x+h) and distribute the minus sign across the entire second expression.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{3x+3h-5-3x+5}{h}"
                },
                {
                  "id": "linear-combine-terms",
                  "label": "Combine like terms",
                  "explanation": "The 3x and -3x terms cancel, and the constant terms -5 and +5 cancel.",
                  "latex": "f'(x)=\\lim_{h\\to 0}\\frac{3h}{h}"
                },
                {
                  "id": "linear-cancel-h",
                  "label": "Cancel h while h is not zero",
                  "explanation": "Before evaluating the limit, h is a nonzero horizontal gap, so 3h divided by h simplifies to 3.",
                  "latex": "f'(x)=\\lim_{h\\to 0}3,\\quad h\\ne 0"
                },
                {
                  "id": "linear-evaluate-limit",
                  "label": "Evaluate the limit",
                  "explanation": "The simplified expression is constant, so the limit is that constant value.",
                  "latex": "f'(x)=3"
                }
              ],
              "interpretation": "The derivative is the constant slope of the line y = 3x - 5."
            },
            {
              "type": "commonMistake",
              "id": "forget-parentheses-around-linear-function",
              "title": "Forgetting to subtract the whole function",
              "misconception": "Subtracting f(x) = 3x - 5 means only subtracting the 3x term.",
              "incorrectStep": "Writing (3(x+h)-5)-3x-5 instead of (3(x+h)-5)-(3x-5).",
              "whyWrong": "The entire value f(x) is being subtracted, so the minus sign must apply to both 3x and -5.",
              "correction": "Keep f(x) in parentheses when substituting, then distribute the subtraction: -(3x-5) = -3x + 5.",
              "checkPrompt": "Did you subtract every term in f(x), including the constant term?"
            },
            {
              "type": "commonMistake",
              "id": "substitute-h-too-early",
              "title": "Substituting h = 0 too early",
              "misconception": "The limit h -> 0 means h can be replaced with 0 immediately.",
              "incorrectStep": "Writing ((x + 0)^2 - x^2) / 0 at the start of the calculation.",
              "whyWrong": "That creates division by zero before the expression has been simplified.",
              "correction": "Keep h nonzero while simplifying, cancel the common factor h, then evaluate the limit.",
              "checkPrompt": "Can the expression still contain division by h when you substitute h = 0?"
            },
            {
              "type": "quiz",
              "id": "first-principles-check",
              "title": "Check your understanding",
              "questions": [
                {
                  "kind": "multipleChoice",
                  "id": "valid-cancellation-step",
                  "prompt": [
                    {
                      "kind": "text",
                      "value": "Which step makes it valid to evaluate the limit for "
                    },
                    {
                      "kind": "inlineMath",
                      "latex": "\\frac{(x+h)^2-x^2}{h}"
                    },
                    {
                      "kind": "text",
                      "value": "?"
                    }
                  ],
                  "options": [
                    {
                      "id": "factor-before-limit",
                      "text": [
                        {
                          "kind": "text",
                          "value": "Factor the numerator as "
                        },
                        {
                          "kind": "inlineMath",
                          "latex": "h(2x+h)"
                        },
                        {
                          "kind": "text",
                          "value": ", cancel h while "
                        },
                        {
                          "kind": "inlineMath",
                          "latex": "h\\ne 0"
                        },
                        {
                          "kind": "text",
                          "value": ", then take the limit."
                        }
                      ],
                      "feedback": "Correct. The cancellation happens before evaluating the limit, while h still represents a nonzero gap."
                    },
                    {
                      "id": "substitute-zero-first",
                      "text": [
                        {
                          "kind": "text",
                          "value": "Substitute "
                        },
                        {
                          "kind": "inlineMath",
                          "latex": "h=0"
                        },
                        {
                          "kind": "text",
                          "value": " immediately."
                        }
                      ],
                      "feedback": "Not yet. That creates division by zero before the algebra removes the denominator."
                    },
                    {
                      "id": "cancel-denominator-only",
                      "text": [
                        {
                          "kind": "text",
                          "value": "Cancel the h in the denominator without factoring the numerator."
                        }
                      ],
                      "feedback": "Not yet. A factor can be canceled only when it is a common factor of the whole numerator and denominator."
                    }
                  ],
                  "correctOptionId": "factor-before-limit",
                  "conceptTags": ["difference-quotient", "limits", "algebra"],
                  "hint": "Look for the step that removes division by h without pretending h already equals 0."
                }
              ]
            },
            {
              "type": "quiz",
              "id": "linear-function-check",
              "title": "Linear function check",
              "questions": [
                {
                  "kind": "shortAnswer",
                  "id": "slope-of-linear-function",
                  "prompt": [
                    {
                      "kind": "text",
                      "value": "For "
                    },
                    {
                      "kind": "inlineMath",
                      "latex": "f(x)=3x-5"
                    },
                    {
                      "kind": "text",
                      "value": ", what is "
                    },
                    {
                      "kind": "inlineMath",
                      "latex": "f'(x)"
                    },
                    {
                      "kind": "text",
                      "value": " from first principles?"
                    }
                  ],
                  "acceptedAnswers": ["3", "f'(x)=3", "f prime of x equals 3"],
                  "feedback": {
                    "correct": "Correct. The difference quotient simplifies to 3 before the limit is evaluated.",
                    "incorrect": "Review the substitution carefully. After distributing the subtraction, the quotient becomes 3h/h while h is nonzero, so the limit is 3."
                  },
                  "conceptTags": ["linear-functions", "difference-quotient", "limits"],
                  "hint": "After simplifying, the expression no longer depends on x or h."
                }
              ]
            },
            {
